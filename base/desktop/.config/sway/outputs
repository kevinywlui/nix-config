# Managed by nwg-displays ($mod+a). Uses monitor descriptions, not connector names,
# so layout survives port changes and dock use.

output "HP Inc. HP Z27n G2 6CM9450CMR" {
    mode  2560x1440@59.951Hz
    pos 1440 0
    transform normal
    scale 1.0
    scale_filter nearest
    adaptive_sync off
    dpms on
}
output "eDP-1" {
    mode  2880x1920@120.0Hz
    pos 0 0
    transform normal
    scale 2.0
    scale_filter nearest
    adaptive_sync off
    dpms on
}
