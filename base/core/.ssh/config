# SSH client config. Symlinked to ~/.ssh/config by nix/modules/home/profiles/core.nix
# (mkOutOfStoreSymlink), so it also works under GNU Stow on non-NixOS hosts.

# Connection multiplexing toward the t480: the first session opens a master
# connection; subsequent `ssh`/`scp`/`rsync` sessions to the same host reuse it
# over the existing socket, skipping the TCP + auth handshake. ControlPersist
# keeps the master alive briefly after the last session closes so rapid
# reconnects stay instant.
Host t480 t480.tail478cf0.ts.net
    HostName t480.tail478cf0.ts.net
    User klui
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%C
    ControlPersist 10m
    ServerAliveInterval 30
    ServerAliveCountMax 3
